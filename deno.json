{
  "$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["deno.window", "deno.unstable"]
  },
  "tasks": {
    "dev": "deno run --watch --unstable-kv --allow-net --allow-env --allow-read main.ts",
    "start": "deno run --unstable-kv --allow-net --allow-env --allow-read main.ts",
    "test": "deno test --unstable-kv --allow-net --allow-env --allow-read --allow-write=./local_stos.db",
    "test:unit": "deno test --unstable-kv --allow-env tests/unit",
    "test:integration": "deno test --unstable-kv --allow-net --allow-env --allow-write=./local_stos.db tests/integration",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "check": "deno check main.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false,
    "semiColons": true
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  },
  "imports": {
    "std/": "https://deno.land/std@0.224.0/"
  },
  "unstable": ["kv"]
}
