# ── GitHub App ────────────────────────────────────────────────────────────
# Webhook secret configured on your GitHub App (Settings → Webhook secret).
# Used to verify X-Hub-Signature-256 over the raw request body.
GITHUB_WEBHOOK_SECRET=

# ── Telegram ──────────────────────────────────────────────────────────────
# Bot token from @BotFather. Never referenced outside src/telegram/client.ts.
TELEGRAM_BOT_TOKEN=

# ── Runtime ───────────────────────────────────────────────────────────────
# Max size (bytes) accepted for an incoming webhook body before it is rejected.
# Default: 5 MB.
MAX_PAYLOAD_BYTES=5242880

# Request timeout (ms) applied to the webhook handler.
REQUEST_TIMEOUT_MS=10000

# Max delivery attempts per outbox task before dead-lettering.
MAX_ATTEMPTS=5

# Optional: comma-separated list of installation IDs allowed to send webhooks.
# Leave empty to accept all installations that have routing configured.
ALLOWED_INSTALLATION_IDS=

# Optional: simple per-installation rate limit (requests per 60s window).
RATE_LIMIT_PER_MINUTE=120

# Log level: debug | info | warn | error
LOG_LEVEL=info
